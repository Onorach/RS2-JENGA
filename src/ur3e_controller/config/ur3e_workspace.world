    <model name="jenga_L7_B1"><static>true</static><pose>0.325 0.0 1.1895 0 0 0</pose><link name="link"><collision name="c"><geometry><box><size>0.025 0.075 0.015</size></box></geometry></collision><visual name="v"><geometry><box><size>0.025 0.075 0.015</size></box></geometry><material><ambient>0.38 0.08 0.45 1</ambient><diffuse>0.70 0.15 0.80 1</diffuse></material></visual></link></model>
