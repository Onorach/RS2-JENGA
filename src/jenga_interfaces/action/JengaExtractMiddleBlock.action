# Goal: extract a block from the tower from the middle, then place it elsewhere
uint32 block_index
geometry_msgs/PoseStamped block_pose
geometry_msgs/PoseStamped place_pose
string extract_axis   # e.g. "x", "-x". Empty string → auto-detect from planning scene; explicit string → override.
---
# Result: outcome
bool success
string message
uint8 error_code
---
# Feedback: progress
string current_stage
float32 progress_pct
